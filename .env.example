# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_NAME=nombre_de_tu_base_de_datos

# Email SMTP (Gmail: usar App Password, no la contraseña real de la cuenta)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_app_password_de_gmail

# Aplicación
FRONTEND_URL=http://localhost:3000
JWT_SECRET=genera_un_secret_seguro_con_openssl_rand_base64_32
APP_ENV=development
